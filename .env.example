# Copy this to .env and fill in real values. DO NOT commit .env.

# --- LLM / VLM ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
OPENAI_API_KEY=your_openai_api_key_here
# GOOGLE_API_KEY=

# --- Embeddings ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- SE-layer settings ---
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/lostfound
IMAGE_STORAGE_DIR=./storage/images
MAX_IMAGE_SIZE_MB=5
HTTP_PORT=8000